\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Uncertainty decomposition heatmap for a test sample (A7, $H{=}96$) across eight Weather variables. \textbf  {(a)}~Absolute prediction error. \textbf  {(b)}~Aleatoric (learned) variance dominates, with colorbar range $0$--$4.0$. \textbf  {(c)}~Epistemic (MC Dropout) variance peaks at ${\sim }0.016$, confirming the ${<}0.3\%$ share in Table~\ref {tab:compact_results}. \textbf  {(d)}~Total uncertainty is visually indistinguishable from~(b).}}{5}{}\protected@file@percent }
