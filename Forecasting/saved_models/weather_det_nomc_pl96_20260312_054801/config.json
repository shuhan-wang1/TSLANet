{
  "data": "custom",
  "root_path": "data/weather",
  "data_path": "weather.csv",
  "features": "M",
  "target": "OT",
  "freq": "h",
  "embed": "timeF",
  "seq_len": 96,
  "label_len": 48,
  "pred_len": 96,
  "emb_dim": 32,
  "depth": 2,
  "patch_size": 16,
  "dropout": 0.3,
  "mask_ratio": 0.4,
  "ICB": true,
  "ASB": true,
  "adaptive_filter": true,
  "batch_size": 32,
  "lr": 0.0001,
  "weight_decay": 1e-06,
  "pretrain_epochs": 5,
  "train_epochs": 15,
  "seed": 42,
  "load_from_pretrained": true,
  "probabilistic": false,
  "mc_dropout": false,
  "mc_samples": 50,
  "save_dir": "saved_models"
}